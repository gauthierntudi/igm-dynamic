{
  "name": "igm-next",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "build:cpanel": "BASE_PATH=/igm cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "start:cpanel": "node server.js",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "db:sync-home-cta": "node --env-file=.env.local scripts/db-sync-home-cta.mjs",
    "db:sync-site-settings": "node --env-file=.env.local scripts/db-sync-site-settings.mjs",
    "db:sync-home-strategy": "node --env-file=.env.local scripts/db-sync-home-strategy.mjs",
    "db:sync-home-partners": "node --env-file=.env.local scripts/db-sync-home-partners.mjs",
    "db:sync-home-action": "node --env-file=.env.local scripts/db-sync-home-action.mjs",
    "db:sync-home-orgchart": "node --env-file=.env.local scripts/db-sync-home-orgchart.mjs",
    "db:sync-media-poster": "node --env-file=.env.local scripts/db-sync-media-poster.mjs",
    "seed:site-settings": "npx tsx --env-file=.env.local scripts/seed-site-settings.ts",
    "seed:site-settings:force": "npx tsx --env-file=.env.local scripts/seed-site-settings.ts --force",
    "seed:home-strategy": "npx tsx --env-file=.env.local scripts/seed-home-strategy.ts",
    "seed:home-strategy:force": "npx tsx --env-file=.env.local scripts/seed-home-strategy.ts --force",
    "seed:home-action": "npx tsx --env-file=.env.local scripts/seed-home-action.ts",
    "seed:home-action:force": "npx tsx --env-file=.env.local scripts/seed-home-action.ts --force",
    "seed:home-orgchart": "npx tsx --env-file=.env.local scripts/seed-home-orgchart.ts",
    "seed:home-orgchart:force": "npx tsx --env-file=.env.local scripts/seed-home-orgchart.ts --force",
    "invalidate:media-cdn": "node --env-file=.env.local scripts/invalidate-media-cdn.mjs",
    "media:version-filename": "npx tsx --env-file=.env.local scripts/version-media-filename.ts",
    "media:generate-video-posters": "npx tsx --env-file=.env.local scripts/generate-video-posters.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.850.0",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-s3": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "ffmpeg-static": "^5.3.0",
    "graphql": "^16.8.1",
    "next": "^16.2.6",
    "payload": "3.85.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-toastify": "^11.1.0",
    "sharp": "0.34.2",
    "typescript": "^6.0.3"
  }
}

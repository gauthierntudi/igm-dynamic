# Payload + Neon PostgreSQL
DATABASE_URI=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/igm?sslmode=require
PAYLOAD_SECRET=change-me-min-32-chars-random-string

# URL publique (Vercel / prod)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Upload S3 : true recommandé sur Vercel (upload direct navigateur → S3)
PAYLOAD_CLIENT_UPLOADS=true
# Upload direct des pièces signalement (presign S3). Activé en prod si omis.
# NEXT_PUBLIC_SIGNALEMENT_S3_DIRECT_UPLOAD=true
# SIGNALEMENT_S3_DIRECT_UPLOAD=true

# AWS S3 (+ CloudFront)
S3_BUCKET=igm-assets
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
NEXT_PUBLIC_CDN_URL=
# Optionnel — évite la résolution auto à chaque invalidation
# CLOUDFRONT_DISTRIBUTION_ID=
S3_PUBLIC_PREFIX=public
S3_PRIVATE_PREFIX=private/signalements
# CORS bucket S3 (prod) — autoriser PUT depuis https://www.igmrdc.com pour l’upload direct signalement

# cPanel uniquement — laisser vide sur Vercel
# BASE_PATH=/igm
# NEXT_PUBLIC_BASE_PATH=/igm

# Redirection accueil selon Accept-Language / cookie igm_locale (true / false, défaut : true)
LOCALE_ACCEPT_LANGUAGE_REDIRECT=true

# Section chiffres sur l'accueil (true / false, défaut : false)
HOME_STATS_SECTION_VISIBLE=false

# Assistant chat — requis pour une conversation IA naturelle (RAG + historique)
# Sans clé : recherche par mots-clés dans le contenu CMS uniquement
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Cloudflare Turnstile — formulaire signalement (/denoncer, /en/report)
# Créer un widget sur https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Clés de test Cloudflare (toujours valides en local) :
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Notifications formulaire contact (SMTP)
# CONTACT_NOTIFY_EMAIL=admin@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="IGM Contact <noreply@example.com>"

# Carte contact (optionnel — remplace l’embed IGM par défaut)
# NEXT_PUBLIC_CONTACT_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3978.537995480033!2d15.295193375669728!3d-4.309473846405503!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1a6a3300232a3a87%3A0xadb4aac562811969!2sInspection%20g%C3%A9n%C3%A9rale%20des%20Mines!5e0!3m2!1sfr!2scd!4v1782671827349!5m2!1sfr!2scd

# Cron Vercel — nettoyage pièces signalement orphelines (/api/cron/cleanup-signalement-pieces)
# Générer une valeur aléatoire longue ; Vercel envoie Authorization: Bearer <CRON_SECRET>
# Plan Hobby : max 1 exécution/jour (schedule dans vercel.json). Plan Pro : horaire possible.
# CRON_SECRET=

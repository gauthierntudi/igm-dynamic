# Copier ces clés dans Vercel → Project → Settings → Environment Variables
# Valeurs : reprendre depuis votre .env.local (Production + Preview)
# NE PAS committer ce fichier rempli avec de vraies valeurs.

# --- Obligatoire ---
DATABASE_URI=
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=https://VOTRE-PROJET.vercel.app

# --- S3 / CloudFront ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
NEXT_PUBLIC_CDN_URL=
S3_PUBLIC_PREFIX=public
S3_PRIVATE_PREFIX=private/signalements

# --- Upload admin (recommandé en prod) ---
PAYLOAD_CLIENT_UPLOADS=true

# --- Feature flags ---
HOME_STATS_SECTION_VISIBLE=false
HOME_ORG_CHART_UNITS_VISIBLE=false

# --- Optionnel : chat IA ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Optionnel : emails contact ---
# CONTACT_NOTIFY_EMAIL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Ne PAS définir sur Vercel ---
# BASE_PATH=

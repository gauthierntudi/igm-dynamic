# Neon PostgreSQL (utiliser le connection pooler en prod)
DATABASE_URI=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/igm?sslmode=require

PAYLOAD_SECRET=change-me-min-32-chars-random-string

# URL publique de ce projet (admin + API)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Front Vercel — webhook ISR après publication
FRONT_REVALIDATE_URL=http://localhost:3000/api/revalidate
FRONT_REVALIDATE_SECRET=change-me-shared-secret

# AWS S3 (+ CloudFront en prod)
S3_BUCKET=igm-assets
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# URL publique des médias (CloudFront ou domaine custom)
# ex. https://d123.cloudfront.net ou https://cdn.igm.cd
NEXT_PUBLIC_CDN_URL=

# Préfixes dans le bucket
S3_PUBLIC_PREFIX=public
S3_PRIVATE_PREFIX=private/signalements
